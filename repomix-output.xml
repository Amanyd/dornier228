          {/* Left / Right designations */}
          <text x="-40" y="-15" fill="#aaa" fontSize="14" textAnchor="middle" fontWeight="bold">P</text>
          <text x="-40" y="5" fill="#888" fontSize="10" textAnchor="middle" fontWeight="bold">PSI</text>
          
